{
  "name": "@tidal/menubar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist:dir": "electron-vite build && electron-builder --mac --arm64 --dir --publish never",
    "dist:dmg": "electron-vite build && electron-builder --mac dmg --arm64 --publish never",
    "dist:zip": "electron-vite build && electron-builder --mac zip --arm64 --publish never",
    "dist": "electron-vite build && electron-builder --mac --arm64 --publish never",
    "start": "electron-vite preview",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.tidal.menubar",
    "productName": "Tidal",
    "copyright": "Copyright © 2026 Tidal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDist": "./node_modules/electron/dist",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tanstack/react-query": "^5.100.14",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stock-sdk": "^1.10.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "26.11.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
